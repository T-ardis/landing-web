# landing-web environment variables
#
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is git-ignored; only this `.env.example` is committed.
# landing-web has exactly one backend touchpoint (the Notion waitlist route);
# everything else is a static marketing surface.

# --- Server-only (never sent to the browser) -------------------------------
# Used by the waitlist lead-capture route: src/app/api/waitlist/route.ts.
# Notion internal-integration token (starts with "ntn_" / "secret_").
NOTION_API_KEY=

# ID of the Notion database that receives waitlist / demo leads. The database
# must expose these properties with matching types:
#   Email (title), Signed Up (date),
#   utm_source, utm_medium, utm_campaign, utm_term, utm_content, Referrer (rich_text)
NOTION_DATABASE_ID=

# --- Client (exposed in the browser bundle via NEXT_PUBLIC_*) --------------
# Target of the primary CTAs and the ?email= lead handoff. Points at the live
# demo / sales site (furniture-web, https://app.tardis-ai.com), which consumes
# the ?email= param for auto-auth. Falls back to https://app.tardis-ai.com/.
NEXT_PUBLIC_APP_URL=https://app.tardis-ai.com/

# Calendly event link opened after email capture (email prefilled via ?email=).
# Defaults in code to https://calendly.com/founders-tardis-ai/30min; set this to
# override. (Set it to an empty value to fall back to NEXT_PUBLIC_APP_URL ?email=.)
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/founders-tardis-ai/30min
